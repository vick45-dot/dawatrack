# Copy this file to .env and fill in your MySQL details
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=dawatrack
# Set to true for cloud databases like Aiven (they require SSL)
DB_SSL=false
PORT=3000
# Change this to any long random text - it signs the login cookies
SESSION_SECRET=change-me-to-something-long-and-random

# ---- M-Pesa Daraja (optional; leave unset to run in simulation mode) ----
# MPESA_ENV=sandbox
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_SHORTCODE=174379
# MPESA_PASSKEY=
# MPESA_CALLBACK_URL=https://your-app.onrender.com/mpesa/callback
# MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
# MPESA_SIMULATE=true

# --- M-Pesa (Daraja) ---
# Leave MPESA_SIMULATE=true to demo the automatic flow without Safaricom.
# For real payments: create an app at developer.safaricom.co.ke, fill these in,
# set MPESA_SIMULATE=false, and make sure MPESA_CALLBACK_URL is your PUBLIC
# https URL + /mpesa/callback (works on Render; Safaricom cannot reach localhost).
MPESA_SIMULATE=true
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
MPESA_CALLBACK_URL=
