<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#14231F" />
  <title>Sign in — DawaTrack</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;700;800&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="login-body">
  <main class="login-card">
    <p class="brand login-brand"><span class="brand-cross">✚</span> Dawa<strong>Track</strong></p>
    <h1>Sign in</h1>
    <% if (error) { %><p class="flash flash-error"><%= error %></p><% } %>
    <form method="POST" action="/login">
      <label>Username
        <input type="text" name="username" required autofocus autocomplete="username" />
      </label>
      <label>Password
        <input type="password" name="password" required autocomplete="current-password" />
      </label>
      <button type="submit" class="btn btn-block">Sign in</button>
    </form>
  </main>
</body>
</html>
