<%- include('partials/header') %>

<h1 class="page-title">Products</h1>
<% if (msg) { %><p class="flash"><%= msg %></p><% } %>

<div class="two-col">
  <section class="panel">
    <form method="GET" action="/products" class="search-form">
      <input type="text" name="q" value="<%= q %>" placeholder="Search by name or category…" />
      <button type="submit" class="btn ghost">Search</button>
    </form>
    <table>
      <thead>
        <tr><th>Product</th><th>Category</th><th class="num">On hand</th><th class="num">Avg cost</th><th class="num">Sell price</th><th class="num">Reorder at</th></tr>
      </thead>
      <tbody>
        <% if (!products.length) { %>
          <tr><td colspan="6" class="muted">No products found. Add your first product on the right.</td></tr>
        <% } %>
        <% products.forEach(p => { %>
        <tr class="<%= p.on_hand <= p.reorder_level ? 'row-low' : '' %>">
          <td><%= p.name %></td>
          <td class="muted"><%= p.category %></td>
          <td class="num mono"><%= p.on_hand %> <%= p.unit %></td>
          <td class="num mono"><%= kes(p.avg_cost) %></td>
          <td class="num mono"><%= p.selling_price !== null ? kes(p.selling_price) : '—' %></td>
          <td class="num mono"><%= p.reorder_level %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </section>

  <section class="panel form-panel">
    <h2>Add product</h2>
    <form method="POST" action="/products">
      <label>Product name
        <input type="text" name="name" required placeholder="e.g. Panadol 500mg (24s)" />
      </label>
      <label>Category
        <input type="text" name="category" placeholder="e.g. Painkillers" />
      </label>
      <label>Unit
        <input type="text" name="unit" placeholder="packet, bottle, tube…" />
      </label>
      <label>Selling price per unit (KES)
        <input type="number" name="selling_price" min="0" step="0.01" placeholder="counter price sellers must use" />
      </label>
      <label>Reorder level
        <input type="number" name="reorder_level" min="0" value="10" />
      </label>
      <button type="submit" class="btn">Save product</button>
    </form>
  </section>
</div>

<%- include('partials/footer') %>
